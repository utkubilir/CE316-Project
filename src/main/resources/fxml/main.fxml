<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.iae.controller.MainController"
            styleClass="root-pane">

    <top>
        <VBox spacing="0">
            <children>
                <MenuBar>
                    <menus>
                        <Menu text="File">
                            <items>
                                <MenuItem fx:id="newProjectMenuItem" text="New Project" onAction="#onNewProject"/>
                                <MenuItem fx:id="openProjectMenuItem" text="Open Project..." onAction="#onOpenProject"/>
                                <MenuItem fx:id="saveProjectMenuItem" text="Save Project" onAction="#onSaveProject"/>
                                <MenuItem fx:id="deleteProjectMenuItem" text="Delete Project..." onAction="#onDeleteProject"/>
                                <SeparatorMenuItem/>
                                <MenuItem fx:id="importConfigMenuItem" text="Import Configuration" onAction="#onImportConfig"/>
                                <MenuItem fx:id="exportConfigMenuItem" text="Export Configuration" onAction="#onExportConfig"/>
                                <SeparatorMenuItem/>
                                <MenuItem text="Exit" onAction="#onExit"/>
                            </items>
                        </Menu>
                        <Menu text="Configuration">
                            <items>
                                <MenuItem fx:id="manageConfigsMenuItem" text="Manage Configurations..." onAction="#onManageConfigs"/>
                            </items>
                        </Menu>
                        <Menu text="Help">
                            <items>
                                <MenuItem text="Manual" onAction="#onShowManual"/>
                                <MenuItem text="About" onAction="#onAbout"/>
                            </items>
                        </Menu>
                    </menus>
                </MenuBar>

                <HBox styleClass="context-bar" spacing="18" alignment="CENTER_LEFT">
                    <padding><Insets top="10" right="18" bottom="10" left="18"/></padding>
                    <children>
                        <VBox spacing="2">
                            <children>
                                <Label text="Project" styleClass="context-eyebrow"/>
                                <Label fx:id="projectNameLabel" text="No active project" styleClass="context-value"
                                       maxWidth="230" textOverrun="ELLIPSIS"/>
                            </children>
                        </VBox>
                        <Separator orientation="VERTICAL"/>
                        <VBox spacing="2">
                            <children>
                                <Label text="Configuration" styleClass="context-eyebrow"/>
                                <Label fx:id="configNameLabel" text="No configuration selected" styleClass="context-value"
                                       maxWidth="240" textOverrun="ELLIPSIS"/>
                            </children>
                        </VBox>
                        <Separator orientation="VERTICAL"/>
                        <VBox spacing="2">
                            <children>
                                <Label text="Submissions" styleClass="context-eyebrow"/>
                                <Label fx:id="submissionCountLabel" text="0 ZIP files" styleClass="context-value"
                                       maxWidth="130" textOverrun="ELLIPSIS"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox spacing="2" alignment="CENTER_RIGHT">
                            <children>
                                <Label text="Last Run" styleClass="context-eyebrow"/>
                                <Label fx:id="lastRunLabel" text="Not run yet" styleClass="context-value-muted"
                                       maxWidth="170" textOverrun="ELLIPSIS"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <left>
        <BorderPane styleClass="sidebar">
            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="8" styleClass="sidebar-body">
                            <padding><Insets top="12" right="14" bottom="10" left="14"/></padding>
                            <children>
                                <GridPane hgap="8" vgap="8">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <children>
                                        <Button fx:id="newProjectBtn" text="_New" maxWidth="Infinity" styleClass="side-btn"
                                                GridPane.columnIndex="0" GridPane.rowIndex="0"
                                                accessibleText="Create a new project" onAction="#onNewProject"/>
                                        <Button fx:id="openProjectBtn" text="_Open" maxWidth="Infinity" styleClass="side-btn"
                                                GridPane.columnIndex="1" GridPane.rowIndex="0"
                                                accessibleText="Open a saved project" onAction="#onOpenProject"/>
                                        <Button fx:id="saveProjectBtn" text="_Save" maxWidth="Infinity" styleClass="side-btn"
                                                GridPane.columnIndex="0" GridPane.rowIndex="1"
                                                accessibleText="Save the active project" onAction="#onSaveProject"/>
                                        <Button fx:id="deleteProjectBtn" text="_Delete" maxWidth="Infinity" styleClass="danger-btn"
                                                GridPane.columnIndex="1" GridPane.rowIndex="1"
                                                accessibleText="Delete a saved project" onAction="#onDeleteProject"/>
                                    </children>
                                </GridPane>

                                <Separator/>

                                <Label text="Submission Folder:" styleClass="side-label" labelFor="$submissionFolderField"/>
                                <TextField fx:id="submissionFolderField" promptText="/path/to/student_submissions" styleClass="side-input"/>
                                <HBox spacing="8">
                                    <children>
                                        <Button fx:id="browseSubmissionsBtn" text="_Browse..." maxWidth="Infinity"
                                                HBox.hgrow="ALWAYS" styleClass="side-btn-secondary"
                                                accessibleText="Choose submissions folder" onAction="#onBrowseSubmissions"/>
                                        <Button fx:id="scanSubmissionsBtn" text="_Scan" maxWidth="Infinity"
                                                HBox.hgrow="ALWAYS" styleClass="side-btn-secondary"
                                                accessibleText="Scan typed submissions folder" onAction="#onScanSubmissions"/>
                                    </children>
                                </HBox>

                                <Label text="Expected Output File:" styleClass="side-label" labelFor="$expectedOutputField"/>
                                <TextField fx:id="expectedOutputField" promptText="/path/to/expected_output.txt" styleClass="side-input"/>
                                <Button fx:id="browseExpectedOutputBtn" text="_Browse..." maxWidth="Infinity" styleClass="side-btn-secondary"
                                        accessibleText="Choose expected output file" onAction="#onBrowseExpectedOutput"/>

                                <Label fx:id="projectValidationLabel" text="" styleClass="validation-text" wrapText="true"/>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
            <bottom>
                <VBox spacing="8" styleClass="sidebar-actions">
                    <padding><Insets top="10" right="14" bottom="14" left="14"/></padding>
                    <children>
                        <Label fx:id="readinessLabel" text="Create or open a project first." styleClass="side-help"
                               wrapText="true"/>
                        <Button fx:id="runTestsBtn" text="_Run Tests" maxWidth="Infinity" styleClass="run-btn"
                                accessibleText="Run tests for discovered submissions" onAction="#onRunTests"/>
                        <ProgressBar fx:id="runProgress" progress="0" maxWidth="Infinity" visible="false" managed="false"/>
                        <Label fx:id="currentRunLabel" text="" styleClass="side-help" wrapText="true"/>
                        <Button fx:id="cancelRunBtn" text="_Cancel Run" maxWidth="Infinity" styleClass="side-btn-secondary"
                                accessibleText="Cancel running evaluation" onAction="#onCancelRun"
                                visible="false" managed="false"/>
                    </children>
                </VBox>
            </bottom>
        </BorderPane>
    </left>

    <center>
        <VBox spacing="0">
            <children>
                <TabPane fx:id="mainTabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="main-tabs"
                         minHeight="180">
                    <tabs>
                        <Tab text="Configuration">
                            <content>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                            styleClass="config-scroll">
                                    <content>
                                        <VBox spacing="12" styleClass="config-pane">
                                            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                                            <children>
                                                <GridPane hgap="12" vgap="12" maxWidth="Infinity">
                                                    <columnConstraints>
                                                        <ColumnConstraints minWidth="140" prefWidth="150"/>
                                                        <ColumnConstraints hgrow="ALWAYS"/>
                                                        <ColumnConstraints minWidth="90"/>
                                                    </columnConstraints>
                                                    <rowConstraints>
                                                        <RowConstraints/>
                                                        <RowConstraints/>
                                                        <RowConstraints/>
                                                        <RowConstraints/>
                                                    </rowConstraints>

                                                    <Label text="Configuration:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                                           labelFor="$configCombo"/>
                                                    <ComboBox fx:id="configCombo" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                                              maxWidth="320"/>
                                                    <Button fx:id="manageConfigBtn" text="Manage..." GridPane.rowIndex="0" GridPane.columnIndex="2"
                                                            maxWidth="Infinity" onAction="#onManageConfigs"/>

                                                    <Label text="Language:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                                    <Label fx:id="configLanguageLabel" text="No language specified"
                                                           styleClass="readonly-value" maxWidth="Infinity"
                                                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                                                           GridPane.columnSpan="2"/>

                                                    <Label text="Source File:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                                                           labelFor="$sourceFileField"/>
                                                    <TextField fx:id="sourceFileField" promptText="main.c"
                                                               GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="2"/>

                                                    <Label text="Compile Command:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                                                           labelFor="$compileCmdField"/>
                                                    <TextField fx:id="compileCmdField" promptText="/usr/bin/gcc main.c -o main"
                                                               GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="2"/>

                                                    <Label text="Run Command:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                                                           labelFor="$runCmdField"/>
                                                    <TextField fx:id="runCmdField" promptText="./main arg1 arg2 arg3"
                                                               GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="2"/>
                                                </GridPane>

                                                <Label fx:id="configValidationLabel" text="" styleClass="validation-text" wrapText="true"/>

                                                <HBox alignment="CENTER_RIGHT">
                                                    <children>
                                                        <Button fx:id="saveConfigBtn" text="Save Config As..." styleClass="save-btn"
                                                                accessibleText="Save current configuration under a name"
                                                                onAction="#onSaveConfig"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </Tab>

                        <Tab text="Student Submissions">
                            <content>
                                <VBox spacing="10" styleClass="config-pane">
                                    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label text="Submission ZIPs discovered in folder:" styleClass="section-label"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="submissionTableHint" text="Choose a folder to preview ZIP files."
                                                       styleClass="muted-text" maxWidth="260" textOverrun="ELLIPSIS"/>
                                            </children>
                                        </HBox>
                                        <TableView fx:id="submissionsTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colSubZip" text="ZIP File" prefWidth="280"/>
                                                <TableColumn fx:id="colSubStudent" text="Student ID" prefWidth="140"/>
                                                <TableColumn fx:id="colSubSize" text="Size" prefWidth="100"/>
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="Expected Output">
                            <content>
                                <VBox spacing="10" styleClass="config-pane">
                                    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label text="Expected Output File Content:" styleClass="section-label"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="expectedOutputHintLabel" text="No file loaded"
                                                       styleClass="muted-text" maxWidth="350" textOverrun="ELLIPSIS"/>
                                            </children>
                                        </HBox>
                                        <TextArea fx:id="expectedOutputTextArea" VBox.vgrow="ALWAYS"
                                                  promptText="Expected output content will appear here..."
                                                  accessibleText="Expected output file contents"
                                                  styleClass="dialog-input" wrapText="false"/>
                                        <HBox alignment="CENTER_RIGHT" spacing="10">
                                            <children>
                                                <Button fx:id="loadExpectedOutputBtn" text="_Load File" styleClass="side-btn-secondary"
                                                        accessibleText="Load expected output file contents"
                                                        onAction="#onLoadExpectedOutput"/>
                                                <Button fx:id="detachExpectedOutputBtn" text="_Detach File" styleClass="side-btn-secondary"
                                                        accessibleText="Detach expected output file from the project"
                                                        onAction="#onClearExpectedOutput"/>
                                                <Button fx:id="saveExpectedOutputBtn" text="_Save Changes" styleClass="save-btn"
                                                        accessibleText="Save edited expected output contents"
                                                        onAction="#onSaveExpectedOutput"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>

                <VBox styleClass="results-section" spacing="6" VBox.vgrow="ALWAYS">
                    <padding><Insets top="10" right="18" bottom="10" left="18"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Test Results" styleClass="section-label"/>
                                <Label fx:id="resultsSummaryLabel" text="No results yet" styleClass="muted-text"
                                       maxWidth="360" textOverrun="ELLIPSIS"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Filter:" styleClass="muted-text" labelFor="$statusFilterCombo"/>
                                <ComboBox fx:id="statusFilterCombo" prefWidth="180"/>
                            </children>
                        </HBox>
                        <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="130"/>
                                <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
                                <TableColumn fx:id="colDetails" text="Details" prefWidth="430"/>
                                <TableColumn fx:id="colActions" text="" prefWidth="90" sortable="false" resizable="false"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox styleClass="status-bar" spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="6" right="12" bottom="6" left="12"/></padding>
            <children>
                <Label fx:id="statusLeft" text="Ready." styleClass="status-text"
                       maxWidth="620" textOverrun="ELLIPSIS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusRight" text="" styleClass="status-text-muted"
                       maxWidth="260" textOverrun="ELLIPSIS"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
